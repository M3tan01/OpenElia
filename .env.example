# OpenElia Environment Configuration Template

# --- EXPENSIVE BRAIN (Claude / Gemini / OpenAI) ---
# See COMMANDS.txt Section 6 for detailed setup.
EXPENSIVE_BRAIN_URL=https://api.openai.com/v1
EXPENSIVE_BRAIN_KEY=your_key_here
EXPENSIVE_MODEL=gpt-4o

# --- SPECIALIZED API KEYS ---
GEMINI_API_KEY=your_gemini_key_here
SHODAN_API_KEY=your_shodan_key_here
VT_API_KEY=your_virustotal_key_here
GRAYNOISE_API_KEY=your_graynoise_key_here
THEHIVE_API_KEY=your_thehive_url_or_key_here

# --- OPERATIONAL CONSTRAINTS ---
# Authorized subnet for testing (RoE)
CYBER_RISK_INSTRUCTION="Strictly adhere to the defined scope. Execute only authorized operations. Never perform non-reversible destructive actions."
MAX_TOKEN_BUDGET=5.00
